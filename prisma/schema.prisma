generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String         @id @default(cuid())
  name              String
  email             String         @unique
  password          String
  role              String         @default("STUDENT")
  suspended         Boolean        @default(false)
  phone             String?
  city              String?
  address           String?
  level             Int?
  canCreateClasses  Boolean        @default(false)
  reservations      Reservation[]
  waitlistEntries   WaitlistEntry[]
  instructorClasses  Class[]             @relation("InstructorClasses")
  sentMessages       Message[]           @relation("SentMessages")
  receivedMessages   Message[]           @relation("ReceivedMessages")
  givenEvaluations   ClassEvaluation[]   @relation("ProfesorEvaluations")
  createdAt         DateTime       @default(now())
}

model Class {
  id               String         @id @default(cuid())
  title            String
  description      String?
  instructor       String
  instructorUserId String?
  instructorUser   User?          @relation("InstructorClasses", fields: [instructorUserId], references: [id])
  datetime         DateTime
  durationMins     Int
  maxCapacity      Int
  levelId          Int?
  level            Level?         @relation(fields: [levelId], references: [id])
  recurringGroupId String?
  reservations     Reservation[]
  waitlistEntries  WaitlistEntry[]
  createdAt        DateTime       @default(now())
}

model Message {
  id         String   @id @default(cuid())
  from       User     @relation("SentMessages", fields: [fromUserId], references: [id])
  fromUserId String
  to         User     @relation("ReceivedMessages", fields: [toUserId], references: [id])
  toUserId   String
  subject    String
  content    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Reservation {
  id         String             @id @default(cuid())
  user       User               @relation(fields: [userId], references: [id])
  userId     String
  class      Class              @relation(fields: [classId], references: [id])
  classId    String
  status     String             @default("ACTIVE")
  attended   Boolean            @default(false)
  absent     Boolean            @default(false)
  evaluation ClassEvaluation?
  createdAt  DateTime           @default(now())

  @@unique([userId, classId])
}

model ClassEvaluation {
  id            String      @id @default(cuid())
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  reservationId String      @unique
  profesor      User        @relation("ProfesorEvaluations", fields: [profesorId], references: [id])
  profesorId    String
  rating        Int
  comment       String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model WaitlistEntry {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  class     Class    @relation(fields: [classId], references: [id])
  classId   String
  createdAt DateTime @default(now())

  @@unique([userId, classId])
}

model Level {
  id      Int     @id @default(autoincrement())
  name    String
  color   String
  order   Int     @default(0)
  classes Class[]
}

model Settings {
  id                String   @id @default("main")
  allowRegistration Boolean  @default(true)
  updatedAt         DateTime @updatedAt
}
